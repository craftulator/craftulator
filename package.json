{
  "name": "craftulator",
  "version": "0.1.0",
  "description": "Universal production-chain calculator for games.",
  "license": "MIT",
  "author": "Dmitriy Ermolaev",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/craftulator/craftulator.github.io.git"
  },
  "bugs": {
    "url": "https://github.com/craftulator/craftulator.github.io/issues"
  },
  "homepage": "https://craftulator.github.io/",
  "keywords": [
    "calculator",
    "crafting",
    "games",
    "production-chain-calculator",
    "react",
    "react-intl",
    "react-router-dom",
    "typescript",
    "vite"
  ],
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "vite build",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build",
    "clean": "rimraf dist coverage",
    "dev": "vite",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src vite.config.ts *.tests.ts",
    "lint-staged": "lint-staged",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "10.4.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "16.2.7",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.14",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.7"
  },
  "dependencies": {
    "antd": "5.29.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-intl": "10.1.9",
    "react-router-dom": "7.15.1"
  }
}
